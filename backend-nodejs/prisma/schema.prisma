generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @unique @default(uuid()) @map("user_id")
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  password      String
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  sessions      Session[]
  tasks         Task[]
  passwordResets PasswordReset[]

  @@map("user")
}

model Session {
  id        String    @id @unique @default(uuid())
  expiresAt DateTime?
  token     String?    @unique()
  createdAt DateTime  @default(now())
  ipAddress String?
  device    String?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  completed   Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("task")
}


model PasswordReset {
  id       String    @id @default(uuid())
  token     String    @unique
  expiresAt DateTime
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())


  @@map("password_reset")
}
